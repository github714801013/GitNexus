{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "gitnexus-shared": ["../gitnexus-shared/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../gitnexus-shared/src/**/*"]
}
